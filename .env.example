### Shared

DEMARCHE_SIMPLIFIEE_API_TOKEN=placeholder
BREVO_API_KEY=placeholder
NODE_ENV=development
KEY_CHIFFREMENT_DONNEES_INSTRUCTIONS_DOSSIER=placeholder
DATABASE_URL=postgresql://dev:dev_password@localhost:5432/especes_pro_3731

# S3-compatible object storage (Outscale OOS in prod) — single app bucket, prefixed per use (files/, …)
# Valeurs par défaut = rustfs local (conteneur `s3` de compose.dev.yml). En prod, pointer vers Outscale OOS.
AWS_ENDPOINT_URL_S3=http://localhost:9000
AWS_REGION=us-east-1
S3_BUCKET=pitchou-dev
AWS_ACCESS_KEY_ID=rustfsadmin
AWS_SECRET_ACCESS_KEY=rustfsadmin

# PUBLIC_ vars are exposed to the browser: https://svelte.dev/docs/kit/$env-static-public
# Links between the two apps; an empty value hides the link.
PUBLIC_SITE_URL_PITCHOU=http://localhost:5173
PUBLIC_SITE_URL_ADMIN=http://localhost:5174
# Client-side environment label (e.g. "staging"). Leave empty in production.
PUBLIC_PITCHOU_ENV=
# Matomo web analytics (instructeur app). Set to the Matomo site ID for this deploy
# (one site per environment: staging vs production). Leave empty to disable tracking.
PUBLIC_MATOMO_SITE_ID=

### Admin

URL_VISIO=
URL_WEBINAIRE=
URL_GRIST_METRIQUES=
URL_VAULTWARDEN=
URL_PAD_RITUEL=

# ProConnect (OpenID Connect) — admin authentication.
# Credentials come from the ProConnect partner portal; DOMAIN selects the
# environment (integration vs production). See https://partenaires.proconnect.gouv.fr/
PROCONNECT_DOMAIN=fca.integ01.dev-agentconnect.fr
PROCONNECT_CLIENT_ID=placeholder
PROCONNECT_CLIENT_SECRET=placeholder
# Secret used to sign the admin session cookie (any long random string).
ADMIN_SESSION_SECRET=placeholder
# Parent domain shared by sibling app subdomains, so a session is seen across apps
# (e.g. `.pitchou.beta.gouv.fr`). Leave empty for localhost/staging (host-only cookie).
SESSION_COOKIE_DOMAIN=

### Sentry (error monitoring, tracing, session replay, logs)

## Events with the "development" environment are not reported in the Sentry interface.
## Therefore, in development, the environment name should be "dev".
## This is a known issue in Beta and cannot be fixed because only the provider
## has the permissions to configure the self-hosted Sentry instance.
PUBLIC_SENTRY_DEV_ENV=dev

# Leave every value empty to disable Sentry: the SDK becomes a no-op.
# A DSN identifies one Sentry project; use one project per app.
# Server side (Node), read in instrumentation.server.ts:
SENTRY_DSN_INSTRUCTEUR=
SENTRY_DSN_ADMIN=
# Browser side (PUBLIC_ prefix is required to expose the value to the client):
PUBLIC_SENTRY_DSN_INSTRUCTEUR=
PUBLIC_SENTRY_DSN_ADMIN=

# Source map upload at build time — only runs when SENTRY_AUTH_TOKEN is set.
# Never commit a real token.
SENTRY_ORG=
SENTRY_PROJECT_INSTRUCTEUR=
SENTRY_PROJECT_ADMIN=
SENTRY_AUTH_TOKEN=

URL_STAGING=

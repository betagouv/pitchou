DEMARCHE_SIMPLIFIEE_API_TOKEN=
BREVO_API_KEY=
NODE_ENV=development
KEY_CHIFFREMENT_DONNEES_INSTRUCTIONS_DOSSIER=
SITE_URL_PITCHOU=http://localhost:5173
DATABASE_URL=postgresql://dev:dev_password@localhost:5432/especes_pro_3731
# Identifie l'environnement côté client (ex. "staging"). Laisser vide en production.
PUBLIC_PITCHOU_ENV=

# S3-compatible object storage (Outscale OOS in prod) — single app bucket, prefixed per use (files/, …)
# Valeurs par défaut = rustfs local (conteneur `s3` de compose.yml). En prod, pointer vers Outscale OOS.
AWS_ENDPOINT_URL_S3=http://localhost:9000
AWS_REGION=us-east-1
S3_BUCKET=pitchou-dev
AWS_ACCESS_KEY_ID=rustfsadmin
AWS_SECRET_ACCESS_KEY=rustfsadmin
